# Copy this file to .env (same directory as docker-compose.yml) and fill in
# real values. .env is git-ignored -- it's meant to stay on the host only.

# Bootstrap admin account, created once on first startup (when no users
# exist yet). Required to log in at all the first time.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# Optional tuning -- safe to leave commented out to use the app's defaults.
# SESSION_TTL_DAYS=14
# SESSION_MAX_TTL_DAYS=90
# MAX_UPLOAD_MB=15

# Optional: enables Google Books as a fallback for the "scan ISBN" lookup
# feature (Open Library is always tried first and needs no key). See
# docs/deployment.md for why this is skipped without a key.
# GOOGLE_BOOKS_API_KEY=
