# Backblaze B2 credentials
# Create an application key at: https://secure.backblaze.com/app_keys.htm
# The key needs: readFiles, writeFiles, deleteFiles, listBuckets, listFiles
B2_KEY_ID=your-key-id-here
B2_APPLICATION_KEY=your-application-key-here
B2_BUCKET=your-bucket-name-here
B2_PATH=scatterbooks        # prefix/folder within the bucket

# Docker container name (check with: docker ps)
CONTAINER_NAME=scatterbooks-scatterbooks-1

# Where to keep local copies on this host
LOCAL_BACKUP_DIR=/var/backups/scatterbooks

# How many days of local backups to keep (0 = keep forever)
KEEP_LOCAL_DAYS=7
